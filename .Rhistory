make_colorbar_grob <- function(colors, lim, nbreak = 5, title = NULL,
label_gp = gpar(fontsize = 10),
title_gp = gpar(fontsize = 11)) {
n <- length(colors)
y <- seq(0, 1, length.out = n + 1)
# 色条本体放在左侧 35% 宽度内
rects <- lapply(1:n, function(i) {
rectGrob(
x = unit(0.18, "npc"),
y = unit((y[i] + y[i + 1]) / 2, "npc"),
width = unit(0.25, "npc"),
height = unit(y[i + 1] - y[i], "npc"),
just = "center",
gp = gpar(fill = colors[i], col = colors[i])
)
})
ticks <- seq(lim[1], lim[2], length.out = nbreak)
tick_pos <- (ticks - lim[1]) / (lim[2] - lim[1])
tick_segments <- segmentsGrob(
x0 = unit(0.31, "npc"), x1 = unit(0.38, "npc"),
y0 = unit(tick_pos, "npc"), y1 = unit(tick_pos, "npc"),
gp = gpar(col = "black")
)
tick_labels <- textGrob(
label = format(round(ticks, 3), trim = TRUE),
x = unit(0.42, "npc"),
y = unit(tick_pos, "npc"),
just = "left",
gp = label_gp
)
title_grob <- if (!is.null(title)) {
textGrob(
label = title,
x = unit(0.5, "npc"),
y = unit(1.03, "npc"),
just = "bottom",
gp = title_gp
)
} else {
nullGrob()
}
grobTree(
do.call(gList, rects),
tick_segments,
tick_labels,
title_grob
)
}
heatmap.net3 <- function(S,
lim = c(min(S), max(S)),
community = rep(1, (1 + sqrt(1 + 8 * ncol(S))) / 2),
color = bluered(100),
ncol = nrow(S),
show_colorbar = TRUE,
colorbar_title = "Value") {
sidecolor = rep("#b7b7b7", length(community))
colsep0 = NULL
target = "#8c8c8c"
tmp = "#b7b7b7"
for (i in 2:length(community)) {
if (community[i] != community[i - 1]) {
sidecolor[i] = target
target = tmp
tmp = sidecolor[i]
colsep0 = c(colsep0, i - 1)
} else {
sidecolor[i] = sidecolor[i - 1]
}
}
if (class(S)[1] != "matrix") {
S = t(as.matrix(S))
}
minS = lim[1]
maxS = lim[2]
# breaks 最好用 length(color)+1 个点
breaks_seq = seq(minS, maxS, length.out = length(color) + 1)
ad_S = vector("list", nrow(S))
for (i in 1:nrow(S)) {
ad_S[[i]] = vec_mat(as.numeric(S[i, ]))
}
gl = lapply(1:nrow(S), function(i) {
heatmap.2(
ad_S[[i]],
Rowv = FALSE, Colv = FALSE,
trace = "none",
symbreaks = TRUE,
labRow = NA, labCol = NA,
dendrogram = "none",
RowSideColors = sidecolor,
ColSideColors = sidecolor,
cexRow = 1, cexCol = 1,
colRow = "white", colCol = "white",
margins = c(2, 2),
col = color,
breaks = breaks_seq,
colsep = colsep0, rowsep = colsep0,
sepcolor = "black",
key = FALSE,
lhei = c(0.55, 3.5), lwid = c(0.55, 3.5)
)
grid.echo()
grid.grab()
})
hm_grob <- arrangeGrob(grobs = gl, ncol = ncol, clip = TRUE)
grid.newpage()
if (show_colorbar) {
cb_grob <- make_colorbar_grob(
colors = color,
lim = lim,
nbreak = 5,
title = colorbar_title
)
grid.arrange(
hm_grob, cb_grob,
ncol = 2,
widths = c(16, 3)
)
} else {
grid.draw(hm_grob)
}
}
heatmap.net3(tmp3$S_list[[1]] ,lim=c(0,1),
community = signal$community,
color = colorpanel(n = 100, low = "white", high = "black"))
make_colorbar_grob <- function(colors, lim, nbreak = 5, title = NULL,
pad = 0.06,
label_gp = gpar(fontsize = 10),
title_gp = gpar(fontsize = 11)) {
n <- length(colors)
# 给上下留白
y <- seq(pad, 1 - pad, length.out = n + 1)
rects <- lapply(1:n, function(i) {
rectGrob(
x = unit(0.18, "npc"),
y = unit((y[i] + y[i + 1]) / 2, "npc"),
width = unit(0.25, "npc"),
height = unit(y[i + 1] - y[i], "npc"),
just = "center",
gp = gpar(fill = colors[i], col = colors[i])
)
})
ticks <- seq(lim[1], lim[2], length.out = nbreak)
tick_pos <- pad + (ticks - lim[1]) / (lim[2] - lim[1]) * (1 - 2 * pad)
tick_segments <- segmentsGrob(
x0 = unit(0.31, "npc"), x1 = unit(0.38, "npc"),
y0 = unit(tick_pos, "npc"), y1 = unit(tick_pos, "npc"),
gp = gpar(col = "black")
)
tick_labels <- textGrob(
label = format(round(ticks, 3), trim = TRUE),
x = unit(0.42, "npc"),
y = unit(tick_pos, "npc"),
just = "left",
gp = label_gp
)
title_grob <- if (!is.null(title)) {
textGrob(
label = title,
x = unit(0.5, "npc"),
y = unit(1 - pad / 2, "npc"),
just = "bottom",
gp = title_gp
)
} else {
nullGrob()
}
grobTree(
do.call(gList, rects),
tick_segments,
tick_labels,
title_grob
)
}
heatmap.net3 <- function(S,
lim = c(min(S), max(S)),
community = rep(1, (1 + sqrt(1 + 8 * ncol(S))) / 2),
